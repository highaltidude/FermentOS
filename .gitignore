# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo

# dependencies
node_modules

# IDEs and editors
/.idea

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/coverage
npm-debug.log
yarn-error.log
pnpm-debug.log

# environment — never commit secrets
.env
.env.local

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Workspace config (local only — not part of the project source)
.cache/
.local/
.upm/
.replit
.replitignore
replit.nix

# Local attached assets (screenshots, uploads)
attached_assets/

# Local agent metadata
.agents/

# Mockup sandbox — design exploration only, not part of the product
artifacts/mockup-sandbox/src/components/mockups/
artifacts/mockup-sandbox/src/.generated/

# Runtime data files — written by the app on the host, not version-controlled
artifacts/api-server/update-history.json
.env.backup

# Claude Code project instructions — local only
CLAUDE.md
